using System;
using System.Collections.Generic;
using System.ComponentModel;
using System.Data;
using System.Drawing;
using System.Linq;
using System.Net;
using System.Text;
using System.Threading;
using System.Threading.Tasks;
using System.Windows.Forms;

namespace Client
{
    public partial class Form1 : Form
    {
        private HttpListener _listener;
        private string _clientId;
        private int _port;
        private TextBox txtLog;
        private Label lblStatus;
        private Button btnCustomCommand;
        private TaskCompletionSource<string> _commandRequest = new TaskCompletionSource<string>();
        public Form1(int port, string clientId)
        {
            _port = port;
            _clientId = clientId;
            InitializeComponent();
            Initalize();
            StartServer();
        }

        private void Initalize()
        {
            this.Text = $"Client {_clientId} - Port {_port}";
            this.txtLog = new TextBox();
            this.lblStatus = new Label();
            this.btnCustomCommand = new Button();
            this.lblStatus.Location = new System.Drawing.Point(12, 9);
            this.lblStatus.Size = new System.Drawing.Size(360, 23);
            this.lblStatus.Text = $"Starting server on port {_port}...";

            this.txtLog.Location = new System.Drawing.Point(12, 38);
            this.txtLog.Size = new System.Drawing.Size(360, 180);
            this.txtLog.Multiline = true;
            this.txtLog.ScrollBars = ScrollBars.Vertical;
            this.txtLog.ReadOnly = true;
            this.btnCustomCommand.Location = new System.Drawing.Point(320, 290);
            this.btnCustomCommand.Size = new System.Drawing.Size(150, 35);
            this.btnCustomCommand.Text = "⚡ Send Custom";
            this.btnCustomCommand.Click += new EventHandler(BtnCustomCommand_Click);
            this.Controls.Add(this.lblStatus);
            this.Controls.Add(this.txtLog);
            this.Controls.Add(this.btnCustomCommand);
        }

        private void StartServer()
        {
            Thread serverThread = new Thread(RunServer);
            serverThread.IsBackground = true;
            serverThread.Start();
        }

        private void RunServer()
        {
            _listener = new HttpListener();
            _listener.Prefixes.Add($"http://localhost:{_port}/");

            try
            {
                _listener.Start();
                LogMessage($"✓ Server started on port {_port}");
                LogMessage($"✓ Client ID: {_clientId}");
                LogMessage($"✓ Listening at: http://localhost:{_port}/");

                UpdateStatus($"Running on port {_port}");

                while (_listener.IsListening)
                {
                    try
                    {
                        var context = _listener.GetContext();
                        ThreadPool.QueueUserWorkItem((o) => HandleRequest(context));
                    }
                    catch (HttpListenerException e)
                    {
                        break;
                    }
                }
            }
            catch (Exception ex)
            {
                LogMessage($"✗ Error: {ex.Message}");
                UpdateStatus("Error starting server");
                MessageBox.Show($"Failed to start server: {ex.Message}", "Error",
                    MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }

        private void LogMessage(string message)
        {
            if (txtLog.InvokeRequired)
            {
                txtLog.Invoke(new Action(() =>
                {
                    txtLog.AppendText($"{DateTime.Now:HH:mm:ss} - {message}\r\n");
                    txtLog.ScrollToCaret();
                }));
            }
            else
            {
                txtLog.AppendText($"{DateTime.Now:HH:mm:ss} - {message}\r\n");
                txtLog.ScrollToCaret();
            }
        }

        private void UpdateStatus(string status)
        {
            if (lblStatus.InvokeRequired)
            {
                lblStatus.Invoke(new Action(() =>
                {
                    lblStatus.Text = status;
                }));
            }
            else
            {
                lblStatus.Text = status;
            }
        }

        private void BtnCustomCommand_Click(Object sender, EventArgs e)
        {
            string command = "notepad";
            if(!_commandRequest.Task.IsCompleted)
            {
                _commandRequest.TrySetResult(command);
            }
            else
            {
                MessageBox.Show("Manager is not connected.Cannot send command.");
            }
        }

        private void HandleRequest(HttpListenerContext context)
        {
            var request = context.Request;
            var response = context.Response;

            if (request.Url.AbsolutePath == "/wait-for-command")
            {
                HandleLongPollingRequest(response);
            }
            else
            {
                string responseText = $"Client {_clientId} is alive on port {_port}";
                byte[] buffer = Encoding.UTF8.GetBytes(responseText);
                response.ContentLength64 = buffer.Length;
                response.OutputStream.Write(buffer, 0, buffer.Length);
                response.OutputStream.Close();
            }
        }
        private void HandleLongPollingRequest(HttpListenerResponse response)
        {
            var task = _commandRequest.Task;
            if (task.Wait(60000))
            {
                string command = task.Result;
                byte[] buffer = Encoding.UTF8.GetBytes(command);
                response.ContentLength64 = buffer.Length;
                response.OutputStream.Write(buffer, 0, buffer.Length);
                response.OutputStream.Close();

                _commandRequest = new TaskCompletionSource<string>();
            }
            else
            {
                byte[] buffer = Encoding.UTF8.GetBytes("TIMEOUT");
                response.ContentLength64 = buffer.Length;
                response.OutputStream.Write(buffer, 0, buffer.Length);
                response.OutputStream.Close();
            }
        }
    }
}

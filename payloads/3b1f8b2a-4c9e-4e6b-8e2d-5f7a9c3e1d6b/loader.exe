        private void InitializeCCListView()
        {
            listView = new CustomListView();
            listView.SetBounds(15, 40, CCPanel.ClientSize.Width - 30, CCPanel.ClientSize.Height - 50);
            listView.Anchor = AnchorStyles.Top | AnchorStyles.Bottom | AnchorStyles.Left | AnchorStyles.Right;
            CCPanel.Controls.Add(listView);
            listView.Columns.Add("ID", 100);
            listView.Columns.Add("Internal IP", 150);
            listView.Columns.Add("External IP", 150);
            listView.Columns.Add("User@PC", 200);
            listView.Columns.Add("OS", 100);
            listView.Columns.Add("Status", 100);
            listView.Columns.Add("Role", 100);
            listView.Columns.Add("Connected C2", 150);
            listView.Columns.Add("Connected MID", 150);
            listView.Columns.Add("View", 150);
            listView.Columns.Add("", 5);
            int[] minWidths = new int[] { 100, 150, 150, 200, 100, 100, 100, 150, 150, 150 };
            listView.setMinimumColumnWidths(minWidths);

            this.Resize += listView.setColumns;

            listView.ColumnWidthChanging += (s, e) => e.Cancel = true;

            AddSampleData();
        }
        public Form1()
        {
            InitializeComponent();
            this.Resize += RATPanel_Resize;
            //Remove the default title bar
            this.FormBorderStyle = FormBorderStyle.None;
            this.BackColor = FORM_BKG_COLOR;
            InitializeCustomTitleBar();
            InitializeCCListView();
        }
        
    }
}
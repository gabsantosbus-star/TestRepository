            item1.SubItems.Add("192.168.1.100");
            item1.SubItems.Add("203.0.113.50");
            item1.SubItems.Add("john@PC-001");
            item1.SubItems.Add("Windows 10");
            item1.SubItems.Add("Connected");
            item1.SubItems.Add("Admin");
            item1.SubItems.Add("C2-Server-01");
            item1.SubItems.Add("MID-12345");
            item1.SubItems.Add("Details");
